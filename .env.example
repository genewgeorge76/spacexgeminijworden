# JWORDENAI Environment Variables
# Copy this file to .env and fill in your API keys
# NEVER commit .env to source control

# ─── AI Model Providers ────────────────────────────────────────────────────
# Claude (Anthropic) — Primary AI for bidding and general queries
VITE_ANTHROPIC_API_KEY=

# OpenAI GPT-4o — Used for scheduling and logistics queries
VITE_OPENAI_API_KEY=

# Google Gemini — Used for specs, VDOT standards, long-context queries
VITE_GEMINI_API_KEY=

# ─── Optional: Local AI (Ollama) ───────────────────────────────────────────
# VITE_OLLAMA_BASE_URL=http://localhost:11434

# ─── Google Intelligence (SEO + Analytics) ────────────────────────────────
# Site URL — used for canonical page_view reporting in GA4
# Set to your production domain (no trailing slash)
VITE_SITE_URL=https://jwordenasphaltpaving.com

# Google Analytics 4 Measurement ID — find in GA4 > Admin > Data Streams
# Format: G-XXXXXXXXXX
VITE_GA4_MEASUREMENT_ID=

# Google Tag Manager Container ID (optional — use if you want GTM layer)
# Format: GTM-XXXXXXX
VITE_GTM_CONTAINER_ID=

# ─── Social Tracking ──────────────────────────────────────────────────────
VITE_FACEBOOK_APP_ID=
VITE_TIKTOK_PIXEL_ID=

# ─── Standalone Ops Backend Bridge ────────────────────────────────────────
# When set, the public contact form mirrors leads to the FastAPI ops backend
# (in the standalone repo). Leave blank to disable; Netlify Forms always
# stays on as the customer-safe persistent log either way.
# Example: https://api.jwordenasphaltpaving.com/api/v1/leads/website
VITE_LEADS_API_URL=

# Public AI concierge endpoint (full URL to /api/v1/public/chat).
# When unset, JarvisChat derives the host from VITE_LEADS_API_URL, then falls
# back to the Railway production URL. Set explicitly when the chat backend
# lives somewhere different than the leads backend.
# Example: https://api.jwordenasphaltpaving.com/api/v1/public/chat
VITE_AI_CHAT_URL=

# ─── Sentry (front-end error reporting) ───────────────────────────────────
# Leave blank to disable. When set, must match the standard Sentry DSN shape:
#   https://<key>@<orgid>.ingest.<region>.sentry.io/<project>
VITE_SENTRY_DSN=
# Optional overrides:
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_TRACES_RATE=0.1
VITE_SENTRY_REPLAY_RATE=0
VITE_SENTRY_REPLAY_ERROR_RATE=1
# Set by CI: VITE_SENTRY_RELEASE=$GITHUB_SHA
# Set to 1 to console.debug each Web Vital (LCP/INP/CLS/FCP/TTFB) in dev
VITE_DEBUG_VITALS=

# ─── Security ─────────────────────────────────────────────────────────────
# Admin dashboard JWT secret (set in Netlify environment, not here)
# ADMIN_JWT_SECRET=

# Founder's Vault passphrase — gates the <FounderGate> wrapper
# NOTE: VITE_* vars are inlined into the client bundle; treat as obfuscation, not secrecy.
VITE_FOUNDER_KEY=
